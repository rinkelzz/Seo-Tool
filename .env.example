# --- Database ---
DATABASE_URL=postgresql+psycopg://seo:seo@db:5432/seo

# --- Redis / RQ ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_API_TOKEN=change-me-to-a-random-string

# --- Crawler defaults ---
CRAWLER_USER_AGENT=SeoToolBot/0.1 (+https://example.local/bot)
CRAWLER_MAX_CONCURRENCY=8
CRAWLER_TIMEOUT_SECONDS=15
CRAWLER_RESPECT_ROBOTS=true

# --- Frontend (Phase 3+) ---
# The frontend reads APP_API_TOKEN at runtime to authenticate against the
# backend. No additional configuration needed for the local docker-compose
# setup — it picks API_URL=http://backend:8000 automatically.

# --- Google Search Console (Phase 4+) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Bing Webmaster Tools (Phase 5+) ---
# BING_WMT_API_KEY=
